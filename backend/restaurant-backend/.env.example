# Copy this file to .env and fill real values. Do not commit .env.

# Database
DB_URL=jdbc:mysql://localhost:3306/pizza_management?useUnicode=true&characterEncoding=UTF-8&useSSL=true&serverTimezone=UTC
DB_USER=change_me
DB_PASS=change_me_strong_password

# JWT: use at least 32 random bytes, preferably 64+ characters.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_AUTH=true
MAIL_USERNAME=change_me@example.com
MAIL_PASSWORD=replace_with_gmail_app_password

# Default bootstrap admin
DEFAULT_ADMIN_PHONE=0900000000
DEFAULT_ADMIN_PASSWORD=ReplaceWithStrongAdminPassword123!
DEFAULT_ADMIN_EMAIL=admin@example.com

# Frontend and CORS
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Runtime storage
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=2097152

# Runtime profile
SPRING_PROFILES_ACTIVE=dev

# VNPay
VNPAY_TMN_CODE=replace_with_tmn_code
VNPAY_HASH_SECRET=replace_with_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5173/payment/vnpay-return
