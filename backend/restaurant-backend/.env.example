# ────────────────────────────────────
# TOÀN BỘ CẤU HÌNH BÍ MẬT CỦA HỆ THỐNG
# ────────────────────────────────────

# 1. DATABASE
DB_URL=jdbc:mysql://host:3306/pizza_management?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=UTC
DB_USER=your_user
DB_PASS=your_pass

# 2. JSON WEB TOKEN
JWT_SECRET=your_secret_key

# 3. GMAIL OTP SENDER
# (Sử dụng App Password do Google cung cấp)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_AUTH=true
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=your_app_password

# 4. TÀI KHOẢN ADMIN MẶC ĐỊNH
DEFAULT_ADMIN_PHONE=0900000000
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_EMAIL=admin@example.com

# 5. LIÊN KẾT FRONTEND
CLIENT_URL=http://localhost:5173

# 6. MÔI TRƯỜNG CHẠY SERVER
SPRING_PROFILES_ACTIVE=dev
