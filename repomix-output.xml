import { useState, useEffect } from "react";
import axios from "axios";
import ProductList from "./ProductList";

export default function MenuSection() {
  const [allProducts, setAllProducts] = useState([]);

  useEffect(() => {
    axios.get("http://localhost:8080/api/products")
      .then(res => setAllProducts(res.data))
      .catch(err => console.error("Lỗi MenuSection:", err));
  }, []);
  const filterByCat = (cat) => allProducts.filter(item => item.category?.toLowerCase() === cat.toLowerCase());

  return (
    <>
      <ProductList title="Combo và những khuyến mãi" products={filterByCat("promotion")}/>
      <ProductList title="Pizza" products={filterByCat("pizza")}/>
      <ProductList title="Gà Vibe" products={filterByCat("chickenVibe")}/>
      <ProductList title="Mì Ý" products={filterByCat("pasta")}/>
      <ProductList title="Nui bỏ lò" products={filterByCat("baked")}/>
