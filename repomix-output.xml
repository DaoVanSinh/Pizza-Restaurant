<file path="client/src/index.css">
/* ================= GLOBAL ================= */

body {
  margin: 0;
  font-family: Arial, sans-serif;
}

img{
  max-width:100%;
  height:auto;
}

/* ================= HEADER ================= */

.header{
  display:flex;
  justify-content: space-between;
  align-items: center;
  margin:0 50px;
  flex-wrap:wrap;
  height:100px;
}

.logo-icon{
  width:100px;
}

.account-icon{
  width:50px;
}

.account-section{
  display:flex;
  align-items:center;
  gap:10px;
}
.account-section a{
  text-decoration: none;
  color:black;
}
.account-section a:hover{
  text-decoration: underline;
  color:#025421;
}
.input{
  display:flex;
  justify-content:center;
}

.input input{
  width:400px;
  height:30px;
  border-radius: 20px;
  border:1px solid black;
}
.input button{
  border-radius: 20px;
  width:80px;
  border: none;
  transition: all 0.3s ease;
  /* background-color: #ffffff; */
}
.input button:hover{
  background-color: #d7d7d7;
}

/* ================= TOPBAR ================= */

.topbar{
  background:#0b6b2d;
  padding:14px 0;
}

.menu{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:25px;
  list-style:none;
  margin:0;
  padding:0;
  flex-wrap:wrap;
}

.menu-item{
  display:inline-block;
  background:#0b6b2d;
  color:white !important;
  text-decoration:none;
  padding:10px 22px;
  border-radius:30px;
  transition:0.3s;
}

.menu-item:hover{
  background:#025421;
}

.menu-item.active{
  background:#063d1a;
}

/* ================= BANNER ================= */

.navbar{
  height:430px;
  margin-top:1%;
}

.navbar img{
  width:100%;
  height:100%;
  object-fit:cover;
}

/* ================= PRODUCT ================= */

.productList h2{
  margin:3% 0 0% 5%;
}

/* grid responsive tự động */

.product-list{
  display:grid;
  grid-template-columns: repeat(auto-fit, minmax(250px,1fr));
  gap:20px;
  margin:5%;
}

/* product card */

.product-card{
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  padding:15px 40px;
  /* padding: 40px; */
  box-sizing:border-box;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08); /* tách nền*/
  transition: transform 0.3s ease;
  border-radius:20px;
}

.product-card:hover,
.Promotion-content:hover{
  /* transform:translateY(-8px); nhảy lên*/
  transform: scale(1.025); /* phóng to */
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.product-card img{
  width: 100%;
  height:200px;
  display: block;
  object-fit:contain;
  border-radius: 20px;;
}

.product-card h3{
  min-height:40px;
  margin-bottom:-10px;
}

.product-card p{
  min-height:50px;
}

.bottom{
  margin-top:auto;
}

.price{
  display:flex;
  justify-content:center;
  align-items:center;
}

.price button,
.promotion-price button{
  margin-left:20px;
  height:40px;
  width:100px;
  border-radius:10px;
  background:white;
  color:#025421;
  border:1px solid #025421;
  transition:0.3s;
}

.price button:hover,
.promotion-price button:hover{
  background:#f42929;
  color:white;
}

/* ================= XEM THÊM ================= */

.Link{
  height:35px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#f0efef;
  border-radius:30px;
  margin:0% 10% 2% 10%;
  transition:0.3s;
  outline:2px solid transparent;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08); /* tách nền*/

}

.Link a{
  color:#025421;
  text-decoration:none;
}

.Link:hover{
  background:#dcfae7;
  outline:2px solid #91f4b7;
  color:#038937;
  box-shadow: 0 20px 20px #91f4b7;
}

/* ================= PROMOTION ================= */

.promotionList h2{
  margin:3% 10% 3% 10%;
}

.Promotion-content{
  display:flex;
